# === Firebase Client (NEXT_PUBLIC_* aman di browser) ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Firebase Admin (server-only, JANGAN prefix NEXT_PUBLIC_) ===
# Download service account JSON dari Firebase Console → Project Settings → Service Accounts.
# Minify jadi satu baris (hapus newline, pakai \n literal di private_key), lalu apit tanda kutip tunggal:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
FIREBASE_SERVICE_ACCOUNT_JSON=

# === Claude API (server-only) ===
# Dipakai untuk: generate-soal (level 0), peta-prasyarat, import-soal PDF.
ANTHROPIC_API_KEY=

# === Google Gemini API (server-only, gratis) ===
# Daftar: https://aistudio.google.com/apikey
# Dipakai untuk: chat-pembahasan, sederhanakan, hint (call ringan & sering).
GEMINI_API_KEY=

# === Leonardo API (server-only, opsional) ===
LEONARDO_API_KEY=
