rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Progress user hanya bisa dibaca/ditulis oleh user ybs
    match /progress/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cache soal & peta prasyarat: read-only dari client,
    // penulisan hanya lewat Admin SDK (server)
    match /soalCache/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /soalManual/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /petaCache/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}
